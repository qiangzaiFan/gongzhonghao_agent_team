{
  "mcpServers": {
    "wenyan-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/你的实际路径/wenyan-mcp/dist/index.js"
      ],
      "env": {
        "WECHAT_APP_ID": "你的情感公众号AppID",
        "WECHAT_APP_SECRET": "你的情感公众号AppSecret"
      }
    },
    "xiaohongshu-mcp": {
      "type": "http",
      "url": "http://localhost:18060/mcp"
    }
  }
}
